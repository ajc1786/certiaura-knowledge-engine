{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.example/schemas/product_passport_lifecycle_record.schema.json",
  "title": "Certiaura Product Passport Lifecycle Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "passport_id",
    "passport_version",
    "review_decision",
    "lifecycle_state",
    "publication",
    "public_claims",
    "lifecycle_events",
    "marketplace",
    "audit",
    "relationships"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "passport_id": {
      "type": "string",
      "pattern": "^PPS-PAS-[A-Z0-9-]{3,80}$"
    },
    "passport_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "source_submission_id": {
      "type": "string",
      "minLength": 3
    },
    "review_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_decision_id",
        "decision_status",
        "public_passport_eligibility",
        "review_decision_sha256",
        "review_effective_until"
      ],
      "properties": {
        "review_decision_id": {
          "type": "string",
          "minLength": 3
        },
        "decision_status": {
          "const": "VERIFIED"
        },
        "public_passport_eligibility": {
          "const": "ELIGIBLE"
        },
        "review_decision_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "review_effective_until": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "lifecycle_state": {
      "enum": [
        "DRAFT",
        "READY_FOR_PUBLICATION",
        "PUBLISHED",
        "SUSPENDED",
        "EXPIRED",
        "WITHDRAWN",
        "SUPERSEDED",
        "ARCHIVED"
      ]
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_slug",
        "effective_from",
        "effective_until",
        "next_review_date",
        "mandatory_disclaimer",
        "publication_gate_passed"
      ],
      "properties": {
        "public_slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "published_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "published_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "effective_from": {
          "type": "string",
          "format": "date"
        },
        "effective_until": {
          "type": "string",
          "format": "date"
        },
        "next_review_date": {
          "type": "string",
          "format": "date"
        },
        "mandatory_disclaimer": {
          "type": "string",
          "minLength": 20
        },
        "publication_gate_passed": {
          "type": "boolean"
        },
        "suspension_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "suspended_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "withdrawal_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "successor_passport_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "superseded_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "public_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "category",
          "display_value",
          "evidence_class",
          "source_review_decision_id",
          "upstream_verified",
          "upstream_public_display_approved",
          "scope_statement",
          "limitations",
          "last_verified_date",
          "next_review_date",
          "visibility"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^CLM-[A-Z0-9-]{3,80}$"
          },
          "category": {
            "type": "string",
            "minLength": 2
          },
          "display_value": {},
          "evidence_class": {
            "enum": [
              "E4",
              "E5"
            ]
          },
          "source_review_decision_id": {
            "type": "string",
            "minLength": 3
          },
          "upstream_verified": {
            "const": true
          },
          "upstream_public_display_approved": {
            "const": true
          },
          "scope_statement": {
            "type": "string",
            "minLength": 10
          },
          "limitations": {
            "type": "string",
            "minLength": 10
          },
          "last_verified_date": {
            "type": "string",
            "format": "date"
          },
          "next_review_date": {
            "type": "string",
            "format": "date"
          },
          "visibility": {
            "const": "PUBLIC"
          }
        }
      },
      "minItems": 1
    },
    "field_visibility": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "visibility"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "visibility": {
            "enum": [
              "PUBLIC",
              "MEMBER",
              "INTERNAL"
            ]
          }
        }
      }
    },
    "lifecycle_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "event_type",
          "severity",
          "detected_at",
          "source",
          "description",
          "required_action",
          "owner",
          "status"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "pattern": "^PPS-EVT-[A-Z0-9-]{3,80}$"
          },
          "event_type": {
            "type": "string",
            "minLength": 3
          },
          "severity": {
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "detected_at": {
            "type": "string",
            "format": "date-time"
          },
          "source": {
            "type": "string",
            "minLength": 2
          },
          "description": {
            "type": "string",
            "minLength": 5
          },
          "required_action": {
            "type": "string",
            "minLength": 3
          },
          "owner": {
            "type": "string",
            "minLength": 2
          },
          "due_date": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "status": {
            "enum": [
              "OPEN",
              "IN_REVIEW",
              "RESOLVED",
              "CLOSED"
            ]
          },
          "resolved_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "resolution": {
            "type": [
              "string",
              "null"
            ]
          },
          "resulting_passport_state": {
            "type": [
              "string",
              "null"
            ]
          },
          "resulting_marketplace_state": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "marketplace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marketplace_state",
        "decision_basis",
        "legal_review_status",
        "regulatory_review_status",
        "supplier_authority_current",
        "commercial_review_status",
        "unresolved_high_or_critical_trigger",
        "decided_at",
        "next_review_date"
      ],
      "properties": {
        "marketplace_decision_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "marketplace_state": {
          "enum": [
            "NOT_ASSESSED",
            "ELIGIBLE",
            "CONDITIONALLY_ELIGIBLE",
            "INELIGIBLE",
            "SUSPENDED",
            "REMOVED"
          ]
        },
        "decision_basis": {
          "type": "string",
          "minLength": 10
        },
        "legal_review_status": {
          "enum": [
            "NOT_STARTED",
            "IN_PROGRESS",
            "COMPLETE",
            "FAILED",
            "NOT_APPLICABLE"
          ]
        },
        "regulatory_review_status": {
          "enum": [
            "NOT_STARTED",
            "IN_PROGRESS",
            "COMPLETE",
            "FAILED",
            "NOT_APPLICABLE"
          ]
        },
        "supplier_authority_current": {
          "type": "boolean"
        },
        "commercial_review_status": {
          "enum": [
            "NOT_STARTED",
            "IN_PROGRESS",
            "COMPLETE",
            "FAILED",
            "NOT_APPLICABLE"
          ]
        },
        "unresolved_high_or_critical_trigger": {
          "type": "boolean"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decided_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "decided_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "next_review_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "created_by",
        "immutable_record",
        "change_requires_new_version_or_event"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string",
          "minLength": 2
        },
        "immutable_record": {
          "const": true
        },
        "change_requires_new_version_or_event": {
          "const": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "target",
          "source"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "strength": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      }
    }
  }
}
