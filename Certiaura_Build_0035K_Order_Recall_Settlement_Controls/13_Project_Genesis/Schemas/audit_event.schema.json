{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Audit Event",
  "type": "object",
  "required": [
    "event_id",
    "record_id",
    "record_type",
    "from_status",
    "to_status",
    "actor_id",
    "actor_role",
    "timestamp",
    "rationale"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "record_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
