{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "event_id",
    "timestamp",
    "actor",
    "actor_type",
    "action",
    "record_type",
    "record_id",
    "reason"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "actor_type": {
      "enum": [
        "HUMAN",
        "AUTOMATION",
        "SYSTEM"
      ]
    },
    "action": {
      "type": "string"
    },
    "record_type": {
      "type": "string"
    },
    "record_id": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    }
  }
}
