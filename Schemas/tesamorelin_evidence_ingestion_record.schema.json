{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/tesamorelin_evidence_ingestion_record.schema.json",
  "title": "tesamorelin_evidence_ingestion_record",
  "type": "object",
  "required": [
    "build_number",
    "record_type",
    "record_id",
    "peptide",
    "clinical_recommendation_authorised",
    "clinical_decision_support_authorised",
    "source_id",
    "source_type",
    "source_locator",
    "source_sha256",
    "retrieved_at",
    "evidence_scope",
    "provenance_state",
    "open_gaps",
    "decision",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0057"
    },
    "candidate": {
      "const": "RC1"
    },
    "peptide": {
      "const": "Tesamorelin"
    },
    "clinical_recommendation_authorised": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_type": {
      "const": "tesamorelin_evidence_ingestion_record"
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "enum": [
        "REGULATORY_LABEL",
        "PEER_REVIEWED",
        "CLINICAL_GUIDANCE",
        "OTHER_CONTROLLED"
      ]
    },
    "source_locator": {
      "type": "string",
      "minLength": 1
    },
    "source_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "retrieved_at": {
      "type": "string",
      "minLength": 1
    },
    "evidence_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "provenance_state": {
      "enum": [
        "VERIFIED",
        "CONDITIONAL",
        "REJECTED"
      ]
    },
    "open_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "enum": [
        "ACCEPT_FOR_SIMULATION",
        "CONDITIONAL_HOLD",
        "REJECT"
      ]
    }
  },
  "additionalProperties": true
}
