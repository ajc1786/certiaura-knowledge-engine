{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "next_peptide_pilot_selection",
  "type": "object",
  "required": [
    "build_number",
    "record_type",
    "selection_id",
    "candidate_assessments",
    "selected_peptide",
    "selection_purpose",
    "clinical_equivalence_claimed",
    "decision",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0055"
    },
    "record_type": {
      "const": "next_peptide_pilot_selection"
    },
    "decision": {
      "enum": [
        "SELECT_GOVERNED_PILOT",
        "CONDITIONAL_PILOT",
        "DEFER",
        "REJECT"
      ]
    },
    "clinical_equivalence_claimed": {
      "const": false
    },
    "candidate_assessments": {
      "type": "array",
      "minItems": 1
    },
    "approvers": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
