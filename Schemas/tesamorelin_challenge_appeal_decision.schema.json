{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/tesamorelin_challenge_appeal_decision.schema.json",
  "title": "tesamorelin_challenge_appeal_decision",
  "type": "object",
  "required": [
    "build_number",
    "candidate",
    "record_type",
    "record_id",
    "peptide",
    "clinical_recommendation_authorised",
    "clinical_decision_support_authorised",
    "challenge_id",
    "original_decision_id",
    "challenge_basis",
    "challenger_role",
    "original_deciders",
    "appeal_panel",
    "independence_confirmed",
    "evidence_pack_version",
    "outcome",
    "rationale",
    "audit_refs",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0059"
    },
    "candidate": {
      "const": "RC1"
    },
    "peptide": {
      "const": "Tesamorelin"
    },
    "clinical_recommendation_authorised": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_type": {
      "const": "tesamorelin_challenge_appeal_decision"
    },
    "challenge_id": {
      "type": "string",
      "minLength": 1
    },
    "original_decision_id": {
      "type": "string",
      "minLength": 1
    },
    "challenge_basis": {
      "type": "string",
      "minLength": 1
    },
    "challenger_role": {
      "type": "string",
      "minLength": 1
    },
    "original_deciders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "appeal_panel": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "independence_confirmed": {
      "type": "boolean"
    },
    "evidence_pack_version": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "enum": [
        "UPHOLD",
        "MODIFY",
        "OVERTURN",
        "HOLD"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "audit_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
