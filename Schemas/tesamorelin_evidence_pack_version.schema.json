{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/tesamorelin_evidence_pack_version.schema.json",
  "title": "tesamorelin_evidence_pack_version",
  "type": "object",
  "required": [
    "build_number",
    "candidate",
    "record_type",
    "record_id",
    "peptide",
    "clinical_recommendation_authorised",
    "clinical_decision_support_authorised",
    "pack_id",
    "version",
    "source_refs",
    "source_hashes",
    "change_summary",
    "immutable_snapshot_hash",
    "validation_state",
    "status",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0059"
    },
    "candidate": {
      "const": "RC1"
    },
    "peptide": {
      "const": "Tesamorelin"
    },
    "clinical_recommendation_authorised": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_type": {
      "const": "tesamorelin_evidence_pack_version"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "predecessor_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "source_hashes": {
      "type": "object"
    },
    "change_summary": {
      "type": "string",
      "minLength": 1
    },
    "immutable_snapshot_hash": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "validation_state": {
      "enum": [
        "COMPLETE",
        "PARTIAL",
        "FAILED"
      ]
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "DRAFT",
        "REVIEW_READY",
        "APPROVED",
        "WITHDRAWN"
      ]
    }
  },
  "additionalProperties": true
}
