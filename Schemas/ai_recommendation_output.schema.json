{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.local/schemas/ai_recommendation_output.schema.json",
  "title": "Certiaura AI Recommendation Output Control Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ai_output_id",
    "output_type",
    "personalisation_level",
    "audience",
    "jurisdiction",
    "health_data_used",
    "intended_purpose",
    "medical_device_assessment",
    "dpia_status",
    "evidence_refs",
    "uncertainty_statement",
    "commercial_interest",
    "human_review",
    "risk_level",
    "disposition",
    "model_version",
    "prompt_record",
    "output_record",
    "status",
    "build_provenance"
  ],
  "properties": {
    "ai_output_id": {
      "type": "string",
      "pattern": "^AI-OUT-[A-Z0-9-]+$"
    },
    "output_type": {
      "enum": [
        "SOURCE_NAVIGATION",
        "EDUCATIONAL_SYNTHESIS",
        "NON_PERSONALISED_COMPARISON",
        "PRODUCT_RANKING",
        "PERSONALISED_RISK",
        "REGIMEN_SUGGESTION",
        "DOSE_OR_TITRATION",
        "DIAGNOSIS",
        "PRESCRIPTION_SELECTION",
        "TREATMENT_PLAN"
      ]
    },
    "personalisation_level": {
      "enum": [
        "NONE",
        "CONTEXTUAL",
        "PERSONAL_HEALTH",
        "CLINICAL"
      ]
    },
    "audience": {
      "enum": [
        "INTERNAL",
        "PROFESSIONAL",
        "PUBLIC",
        "MIXED"
      ]
    },
    "jurisdiction": {
      "type": "string"
    },
    "health_data_used": {
      "type": "boolean"
    },
    "intended_purpose": {
      "type": "string"
    },
    "medical_device_assessment": {
      "enum": [
        "NOT_REQUIRED",
        "PENDING",
        "NOT_A_MEDICAL_DEVICE",
        "POTENTIAL_MEDICAL_DEVICE",
        "QUALIFIED_MEDICAL_DEVICE"
      ]
    },
    "dpia_status": {
      "enum": [
        "NOT_REQUIRED",
        "PENDING",
        "APPROVED",
        "REJECTED"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertainty_statement": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commercial_interest": {
      "type": "boolean"
    },
    "commercial_interest_disclosure": {
      "type": "string"
    },
    "human_review": {
      "type": "object",
      "required": [
        "required",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "NOT_REQUIRED",
            "PENDING",
            "APPROVED",
            "APPROVED_WITH_CONDITIONS",
            "REJECTED"
          ]
        },
        "reviewer": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "risk_level": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "PROHIBITED"
      ]
    },
    "disposition": {
      "enum": [
        "ALLOW",
        "ALLOW_WITH_CONTROLS",
        "HUMAN_REVIEW",
        "REGULATED_PATHWAY_OR_BLOCK",
        "BLOCK"
      ]
    },
    "model_version": {
      "type": "string"
    },
    "prompt_record": {
      "type": "string"
    },
    "output_record": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "build_provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
