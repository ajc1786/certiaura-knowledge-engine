{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.local/schemas/retatrutide_export_version_chain.schema.json",
  "title": "Retatrutide Export Version Chain",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "build_provenance",
    "export_family_id",
    "versions"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "build_provenance": {
      "const": "CERT-BUILD-0048"
    },
    "export_family_id": {
      "type": "string",
      "pattern": "^RET-EXPORT-FAMILY-[A-Z0-9-]+$"
    },
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "export_id",
          "version",
          "sha256",
          "generated_at",
          "state",
          "source_journey_id",
          "source_input_hashes"
        ],
        "properties": {
          "export_id": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-F0-9]{64}$"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time"
          },
          "state": {
            "enum": [
              "DRAFT",
              "APPROVED",
              "CURRENT_APPROVED",
              "SUPERSEDED",
              "WITHDRAWN"
            ]
          },
          "source_journey_id": {
            "type": "string"
          },
          "source_input_hashes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-F0-9]{64}$"
            }
          },
          "predecessor_export_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "approval_review_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "change_summary": {
            "type": "string"
          }
        }
      }
    }
  }
}
