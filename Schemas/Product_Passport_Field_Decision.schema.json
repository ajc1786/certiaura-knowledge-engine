{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.local/schemas/product-passport-field-decision.schema.json",
  "title": "CertiAura Product Passport Field Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_passport",
    "product_uai",
    "field_name",
    "decision",
    "reviewers",
    "evidence_ids",
    "decision_date"
  ],
  "properties": {
    "product_passport": {
      "type": "string",
      "pattern": "^CERT-PPS-[0-9]{6}$"
    },
    "product_uai": {
      "type": "string",
      "pattern": "^CERT-(PKS|MPS)-[0-9]{6}$"
    },
    "field_name": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "OPEN",
        "ACCEPTED",
        "ACCEPTED_WITH_LIMITATION",
        "DEFICIENT",
        "QUARANTINED",
        "REJECTED",
        "SUPERSEDED"
      ]
    },
    "reviewers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_date": {
      "type": "string",
      "format": "date"
    },
    "next_review_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "commercial_release_effect": {
      "const": "NONE_AUTOMATIC"
    }
  }
}
