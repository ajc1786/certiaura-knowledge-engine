{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Retatrutide monitoring domain matrix",
  "type": "object",
  "required": [
    "compound",
    "domains"
  ],
  "properties": {
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "domain_id",
          "purpose",
          "data_elements",
          "evidence_refs",
          "prohibited_output"
        ]
      }
    }
  }
}
