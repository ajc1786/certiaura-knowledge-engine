{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.local/schemas/retatrutide_publication_release.schema.json",
  "title": "Retatrutide Publication Release",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "record_type": {
      "type": "string",
      "const": "RETATRUTIDE_PUBLICATION_RELEASE"
    },
    "build_number": {
      "type": "string",
      "const": "0053"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "peptide_uai": {
      "type": "string",
      "const": "CERT-PKS-000001"
    },
    "release_id": {
      "type": "string",
      "pattern": "^RET-KPR-[0-9]{4}$"
    },
    "implementation_id": {
      "type": "string"
    },
    "approval_state": {
      "type": "string",
      "const": "APPROVED"
    },
    "implementation_state": {
      "type": "string",
      "const": "IMPLEMENTED"
    },
    "publication_state": {
      "type": "string",
      "enum": [
        "DRAFT",
        "UNDER_REVIEW",
        "APPROVED",
        "STAGED",
        "PUBLISHED",
        "WITHDRAWN",
        "SUPERSEDED",
        "ROLLED_BACK"
      ]
    },
    "audience_channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "INTERNAL",
          "PROFESSIONAL",
          "PATIENT",
          "PUBLIC",
          "AI_RESPONSE"
        ]
      },
      "uniqueItems": true
    },
    "published_assets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publication_approval_id": {
      "type": "string"
    },
    "effective_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "responsible_communications_validated": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schema_version",
    "record_type",
    "build_number",
    "created_at",
    "created_by",
    "peptide_uai",
    "release_id",
    "implementation_id",
    "approval_state",
    "implementation_state",
    "publication_state",
    "audience_channels",
    "published_assets",
    "publication_approval_id",
    "effective_at",
    "responsible_communications_validated"
  ]
}
