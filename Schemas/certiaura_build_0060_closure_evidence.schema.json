    "candidate",
    "title",
    "canonical_commit",
    "commit_subject",
    "run_id",
    "workflow_name",
    "run_attempt",
    "branch",
    "event",
    "status",
    "conclusion",
    "created_at",
    "updated_at",
    "actions_url",
    "local_origin_aligned",
    "repository_clean",
    "git_noninteractive_guard",
    "no_manual_cleanup_prompts",
    "endpoint",
    "founder_ready_status"
