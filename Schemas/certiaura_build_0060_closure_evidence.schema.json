    },
    "workflow_name": {
      "const": "Certiaura Repository Validation"
    },
    "run_attempt": {
      "type": "integer",
      "minimum": 1
    },
    "branch": {
      "const": "main"
    },
    "event": {
      "const": "push"
    },
    "status": {
      "const": "completed"
    },
    "conclusion": {
      "const": "success"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "actions_url": {
      "type": "string",
      "minLength": 1
    },
    "local_origin_aligned": {
      "const": true
    },
    "repository_clean": {
      "const": true
    },
    "git_noninteractive_guard": {
      "const": true
    },
    "no_manual_cleanup_prompts": {
      "const": true
    },
    "endpoint": {
      "const": "BUILD_0060_GITHUB_ACTIONS_GREEN"
    },
    "founder_ready_status": {
