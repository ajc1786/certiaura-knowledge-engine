{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/tesamorelin_safety_boundary.schema.json",
  "title": "tesamorelin_safety_boundary",
  "type": "object",
  "required": [
    "build_number",
    "record_type",
    "record_id",
    "peptide",
    "clinical_equivalence_claimed",
    "clinical_decision_support_authorised",
    "contraindication_categories",
    "caution_categories",
    "monitoring_dependencies",
    "stop_or_escalate_triggers",
    "emergency_instruction",
    "boundary_state",
    "decision",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0056"
    },
    "candidate": {
      "const": "RC1"
    },
    "record_type": {
      "const": "tesamorelin_safety_boundary"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "peptide": {
      "const": "Tesamorelin"
    },
    "clinical_equivalence_claimed": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contraindication_categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "caution_categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "monitoring_dependencies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stop_or_escalate_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "emergency_instruction": {
      "type": "string",
      "minLength": 1
    },
    "boundary_state": {
      "enum": [
        "DEFINED",
        "CONDITIONAL",
        "UNDEFINED"
      ]
    },
    "decision": {
      "enum": [
        "ACCEPT_SAFETY_BOUNDARY_FOR_KNOWLEDGE_PILOT",
        "HOLD_FOR_SAFETY_COMPLETENESS"
      ]
    }
  },
  "additionalProperties": true
}
