{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "title": "Retatrutide Follow-Up Review",
  "required": [
    "schema_version",
    "build_provenance",
    "follow_up_id",
    "handoff_bundle_id",
    "acknowledgement_id",
    "subject_reference",
    "state",
    "due_at",
    "reviewer_role_reference",
    "urgent_routing_locked",
    "rationale"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "build_provenance": {
      "const": "CERT-BUILD-0049"
    },
    "follow_up_id": {
      "type": "string"
    },
    "handoff_bundle_id": {
      "type": "string"
    },
    "acknowledgement_id": {
      "type": "string"
    },
    "subject_reference": {
      "type": "string",
      "pattern": "^SUBJ-[A-Z0-9-]+$"
    },
    "state": {
      "enum": [
        "FOLLOW_UP_NOT_DUE",
        "FOLLOW_UP_DUE",
        "FOLLOW_UP_COMPLETED",
        "FOLLOW_UP_OVERDUE",
        "LOCKED_URGENT_ROUTING",
        "CLOSED_NO_FURTHER_ACTION"
      ]
    },
    "due_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "reviewer_role_reference": {
      "type": "string"
    },
    "urgent_routing_locked": {
      "type": "boolean"
    },
    "rationale": {
      "type": "string"
    }
  }
}
