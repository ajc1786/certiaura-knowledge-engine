{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/bpc157_transition_appeal.schema.json",
  "title": "bpc157_transition_appeal",
  "type": "object",
  "required": [
    "build_number",
    "candidate",
    "record_type",
    "record_id",
    "peptide",
    "clinical_recommendation_authorised",
    "clinical_decision_support_authorised",
    "tesamorelin_assumptions_transferred",
    "appeal_id",
    "original_decision_id",
    "appeal_basis",
    "original_deciders",
    "appeal_panel",
    "independence_confirmed",
    "evidence_pack_hash",
    "outcome",
    "rationale",
    "audit_refs",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0060"
    },
    "candidate": {
      "const": "RC1"
    },
    "peptide": {
      "const": "BPC-157"
    },
    "clinical_recommendation_authorised": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "tesamorelin_assumptions_transferred": {
      "const": false
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_type": {
      "const": "bpc157_transition_appeal"
    },
    "appeal_id": {
      "type": "string",
      "minLength": 1
    },
    "original_decision_id": {
      "type": "string",
      "minLength": 1
    },
    "appeal_basis": {
      "type": "string",
      "minLength": 1
    },
    "original_deciders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "appeal_panel": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "independence_confirmed": {
      "type": "boolean"
    },
    "evidence_pack_hash": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "outcome": {
      "enum": [
        "UPHOLD_HOLD",
        "MODIFY_CONDITIONS",
        "RECONSIDER_WITH_NEW_EVIDENCE",
        "REJECT_APPEAL"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "audit_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
