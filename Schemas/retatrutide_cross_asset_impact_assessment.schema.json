{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.local/schemas/retatrutide_cross_asset_impact_assessment.schema.json",
  "title": "Retatrutide Cross-Asset Impact Assessment",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "record_type": {
      "type": "string",
      "const": "RETATRUTIDE_CROSS_ASSET_IMPACT_ASSESSMENT"
    },
    "build_number": {
      "type": "string",
      "const": "0053"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "peptide_uai": {
      "type": "string",
      "const": "CERT-PKS-000001"
    },
    "impact_id": {
      "type": "string",
      "pattern": "^RET-KIA-[0-9]{4}$"
    },
    "change_id": {
      "type": "string",
      "pattern": "^RET-KCH-[0-9]{4}$"
    },
    "impacted_assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "asset_uai": {
            "type": "string"
          },
          "repository_path": {
            "type": "string"
          },
          "surface": {
            "type": "string"
          },
          "intended_action": {
            "type": "string",
            "enum": [
              "UPDATE",
              "SUPERSEDE",
              "NO_CHANGE",
              "HOLD"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 5
          }
        },
        "required": [
          "asset_uai",
          "repository_path",
          "surface",
          "intended_action",
          "reason"
        ]
      }
    },
    "unresolved_assets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "all_declared": {
      "type": "boolean"
    },
    "relationship_changes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "COMPLETE",
        "QUARANTINED",
        "INCOMPLETE"
      ]
    }
  },
  "required": [
    "schema_version",
    "record_type",
    "build_number",
    "created_at",
    "created_by",
    "peptide_uai",
    "impact_id",
    "change_id",
    "impacted_assets",
    "unresolved_assets",
    "all_declared",
    "relationship_changes",
    "status"
  ]
}
