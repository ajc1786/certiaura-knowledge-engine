{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/tesamorelin_evidence_gap_decision.schema.json",
  "title": "tesamorelin_evidence_gap_decision",
  "type": "object",
  "required": [
    "build_number",
    "record_type",
    "record_id",
    "peptide",
    "clinical_equivalence_claimed",
    "clinical_decision_support_authorised",
    "gap_id",
    "gap_category",
    "severity",
    "evidence",
    "decision",
    "required_action",
    "closure_authority",
    "status",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0056"
    },
    "candidate": {
      "const": "RC1"
    },
    "record_type": {
      "const": "tesamorelin_evidence_gap_decision"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "peptide": {
      "const": "Tesamorelin"
    },
    "clinical_equivalence_claimed": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gap_id": {
      "type": "string",
      "minLength": 1
    },
    "gap_category": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": [
        "CRITICAL",
        "NONCRITICAL"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "enum": [
        "RETAIN_OPEN_WITH_CONTROL",
        "CLOSE_WITH_EVIDENCE",
        "ESCALATE"
      ]
    },
    "required_action": {
      "type": "string",
      "minLength": 1
    },
    "closure_authority": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "OPEN_CONTROLLED",
        "CLOSED_EVIDENCED",
        "ESCALATED"
      ]
    }
  },
  "additionalProperties": true
}
