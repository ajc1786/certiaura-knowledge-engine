{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.local/schemas/communication_approval_record.schema.json",
  "title": "Certiaura Communication Approval Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "communication_id",
    "title",
    "audience",
    "jurisdiction",
    "channels",
    "claim_ids",
    "commercial_interest",
    "ai_involvement",
    "required_disclosures",
    "approval_level",
    "reviews",
    "decision",
    "status",
    "build_provenance"
  ],
  "properties": {
    "communication_id": {
      "type": "string",
      "pattern": "^COMM-[A-Z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "enum": [
        "INTERNAL",
        "PROFESSIONAL",
        "PUBLIC",
        "MIXED"
      ]
    },
    "jurisdiction": {
      "type": "string"
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "product_regulatory_classification": {
      "enum": [
        "NOT_APPLICABLE",
        "GENERAL_PRODUCT",
        "MEDICAL_DEVICE",
        "LICENSED_MEDICINE",
        "PRESCRIPTION_ONLY_MEDICINE",
        "UNLICENSED_PRODUCT",
        "UNKNOWN"
      ]
    },
    "commercial_interest": {
      "type": "boolean"
    },
    "commercial_interest_disclosure": {
      "type": "string"
    },
    "ai_involvement": {
      "enum": [
        "NONE",
        "DRAFTING",
        "SYNTHESIS",
        "RECOMMENDATION",
        "PERSONALISATION"
      ]
    },
    "vulnerable_audience_controls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_disclosures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_level": {
      "enum": [
        "L1",
        "L2",
        "L3",
        "L4",
        "BLOCKED"
      ]
    },
    "reviews": {
      "type": "object",
      "required": [
        "scientific",
        "communications",
        "medical",
        "legal_regulatory",
        "data_protection"
      ],
      "properties": {
        "scientific": {
          "enum": [
            "NOT_REQUIRED",
            "PENDING",
            "APPROVED",
            "APPROVED_WITH_CONDITIONS",
            "REJECTED"
          ]
        },
        "communications": {
          "enum": [
            "NOT_REQUIRED",
            "PENDING",
            "APPROVED",
            "APPROVED_WITH_CONDITIONS",
            "REJECTED"
          ]
        },
        "medical": {
          "enum": [
            "NOT_REQUIRED",
            "PENDING",
            "APPROVED",
            "APPROVED_WITH_CONDITIONS",
            "REJECTED"
          ]
        },
        "legal_regulatory": {
          "enum": [
            "NOT_REQUIRED",
            "PENDING",
            "APPROVED",
            "APPROVED_WITH_CONDITIONS",
            "REJECTED"
          ]
        },
        "data_protection": {
          "enum": [
            "NOT_REQUIRED",
            "PENDING",
            "APPROVED",
            "APPROVED_WITH_CONDITIONS",
            "REJECTED"
          ]
        }
      }
    },
    "decision": {
      "enum": [
        "DRAFT",
        "APPROVED",
        "APPROVED_WITH_CONDITIONS",
        "REJECTED",
        "QUARANTINED",
        "WITHDRAWN"
      ]
    },
    "approval_expiry": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "status": {
      "type": "string"
    },
    "build_provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
