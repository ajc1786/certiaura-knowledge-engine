{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/bpc157_safety_quality_boundary.schema.json",
  "title": "bpc157_safety_quality_boundary",
  "type": "object",
  "required": [
    "build_number",
    "candidate",
    "record_type",
    "record_id",
    "peptide",
    "clinical_recommendation_authorised",
    "clinical_decision_support_authorised",
    "tesamorelin_assumptions_transferred",
    "quality_domains",
    "immunogenicity_state",
    "impurity_state",
    "formulation_state",
    "manufacturing_state",
    "critical_unknowns",
    "boundary_decision",
    "source_refs",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0060"
    },
    "candidate": {
      "const": "RC1"
    },
    "peptide": {
      "const": "BPC-157"
    },
    "clinical_recommendation_authorised": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "tesamorelin_assumptions_transferred": {
      "const": false
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_type": {
      "const": "bpc157_safety_quality_boundary"
    },
    "quality_domains": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string"
      }
    },
    "immunogenicity_state": {
      "enum": [
        "CONCERN_IDENTIFIED",
        "CONTROLLED",
        "UNKNOWN"
      ]
    },
    "impurity_state": {
      "enum": [
        "CONCERN_IDENTIFIED",
        "CONTROLLED",
        "UNKNOWN"
      ]
    },
    "formulation_state": {
      "enum": [
        "UNSTANDARDISED",
        "CONTROLLED",
        "UNKNOWN"
      ]
    },
    "manufacturing_state": {
      "enum": [
        "SOURCE_DEPENDENT",
        "VALIDATED",
        "UNKNOWN"
      ]
    },
    "critical_unknowns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "boundary_decision": {
      "enum": [
        "HOLD",
        "CONDITIONAL_HOLD",
        "CONTROLLED_FOR_SIMULATION_ONLY"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "url",
          "authority",
          "verified_at"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "authority": {
            "type": "string",
            "minLength": 1
          },
          "verified_at": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    }
  },
  "additionalProperties": true
}
