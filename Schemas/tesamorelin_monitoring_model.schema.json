{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/tesamorelin_monitoring_model.schema.json",
  "title": "tesamorelin_monitoring_model",
  "type": "object",
  "required": [
    "build_number",
    "record_type",
    "record_id",
    "peptide",
    "clinical_equivalence_claimed",
    "clinical_decision_support_authorised",
    "baseline_domains",
    "ongoing_domains",
    "review_cadence",
    "decision_rules",
    "automation_limit",
    "model_state",
    "decision",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0056"
    },
    "candidate": {
      "const": "RC1"
    },
    "record_type": {
      "const": "tesamorelin_monitoring_model"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "peptide": {
      "const": "Tesamorelin"
    },
    "clinical_equivalence_claimed": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "baseline_domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "ongoing_domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "review_cadence": {
      "type": "string",
      "minLength": 1
    },
    "decision_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "automation_limit": {
      "type": "string",
      "minLength": 1
    },
    "model_state": {
      "enum": [
        "DEFINED",
        "CONDITIONAL",
        "UNDEFINED"
      ]
    },
    "decision": {
      "enum": [
        "ACCEPT_MONITORING_MODEL_FOR_CONTROLLED_PILOT",
        "HOLD_FOR_MONITORING_COMPLETENESS"
      ]
    }
  },
  "additionalProperties": true
}
