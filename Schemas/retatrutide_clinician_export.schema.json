{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.local/schemas/retatrutide_clinician_export.schema.json",
  "title": "Retatrutide Clinician Export",
  "type": "object",
  "required": [
    "schema_version",
    "build_provenance",
    "export_id",
    "journey_id",
    "subject_reference",
    "status",
    "summary",
    "active_alerts",
    "uncertainties",
    "provenance",
    "disclaimer"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "build_provenance": {
      "const": "CERT-BUILD-0047"
    },
    "status": {
      "enum": [
        "DRAFT_FOR_CLINICIAN_REVIEW",
        "CLINICIAN_APPROVED",
        "SUPERSEDED",
        "WITHDRAWN"
      ]
    }
  },
  "additionalProperties": true
}
