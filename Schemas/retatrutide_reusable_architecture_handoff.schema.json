{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reusable_architecture_handoff",
  "type": "object",
  "required": [
    "build_number",
    "record_type",
    "handoff_id",
    "closure_decision_id",
    "generic_components",
    "excluded_peptide_specific_components",
    "handoff_state",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0055"
    },
    "record_type": {
      "const": "reusable_architecture_handoff"
    },
    "handoff_state": {
      "enum": [
        "APPROVED_FOR_GOVERNED_PILOT",
        "PILOT_ONLY",
        "HOLD",
        "REJECT"
      ]
    },
    "generic_components": {
      "type": "array",
      "minItems": 1
    },
    "excluded_peptide_specific_components": {
      "type": "array",
      "minItems": 1
    },
    "approvers": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
