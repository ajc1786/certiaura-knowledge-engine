{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/tesamorelin_evidence_corpus_map.schema.json",
  "title": "tesamorelin_evidence_corpus_map",
  "type": "object",
  "required": [
    "build_number",
    "record_type",
    "record_id",
    "peptide",
    "clinical_equivalence_claimed",
    "clinical_decision_support_authorised",
    "scope",
    "source_records",
    "coverage_state",
    "open_critical_gaps",
    "decision",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0056"
    },
    "candidate": {
      "const": "RC1"
    },
    "record_type": {
      "const": "tesamorelin_evidence_corpus_map"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "peptide": {
      "const": "Tesamorelin"
    },
    "clinical_equivalence_claimed": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "source_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "coverage_state": {
      "enum": [
        "BASELINE_MAPPED",
        "PARTIAL",
        "INSUFFICIENT"
      ]
    },
    "open_critical_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "enum": [
        "ACCEPT_FOR_BOUNDARY_DEFINITION",
        "CONDITIONAL_MAPPING_ONLY",
        "HOLD"
      ]
    }
  },
  "additionalProperties": true
}
