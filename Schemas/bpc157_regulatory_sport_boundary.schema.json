{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certiaura.invalid/schemas/bpc157_regulatory_sport_boundary.schema.json",
  "title": "bpc157_regulatory_sport_boundary",
  "type": "object",
  "required": [
    "build_number",
    "candidate",
    "record_type",
    "record_id",
    "peptide",
    "clinical_recommendation_authorised",
    "clinical_decision_support_authorised",
    "tesamorelin_assumptions_transferred",
    "fda_state",
    "fda_basis",
    "wada_state",
    "wada_basis",
    "human_therapeutic_approval_state",
    "jurisdiction_scope",
    "source_refs",
    "boundary_decision",
    "approvers"
  ],
  "properties": {
    "build_number": {
      "const": "0060"
    },
    "candidate": {
      "const": "RC1"
    },
    "peptide": {
      "const": "BPC-157"
    },
    "clinical_recommendation_authorised": {
      "const": false
    },
    "clinical_decision_support_authorised": {
      "const": false
    },
    "tesamorelin_assumptions_transferred": {
      "const": false
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_type": {
      "const": "bpc157_regulatory_sport_boundary"
    },
    "fda_state": {
      "enum": [
        "PROPOSED_NOT_INCLUDE_503A",
        "PENDING_REVIEW",
        "UNKNOWN"
      ]
    },
    "fda_basis": {
      "type": "string",
      "minLength": 1
    },
    "wada_state": {
      "enum": [
        "S0_PROHIBITED_AT_ALL_TIMES",
        "NOT_PROHIBITED",
        "UNKNOWN"
      ]
    },
    "wada_basis": {
      "type": "string",
      "minLength": 1
    },
    "human_therapeutic_approval_state": {
      "enum": [
        "NO_CURRENT_GOVERNMENTAL_APPROVAL_IDENTIFIED",
        "APPROVED",
        "UNKNOWN"
      ]
    },
    "jurisdiction_scope": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "url",
          "authority",
          "verified_at"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "authority": {
            "type": "string",
            "minLength": 1
          },
          "verified_at": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "boundary_decision": {
      "enum": [
        "BOUNDARY_COMPLETE_HOLD",
        "BOUNDARY_COMPLETE_RESTRICTED",
        "INCOMPLETE"
      ]
    }
  },
  "additionalProperties": true
}
